config_version=5

[application]

config/name="Vyona Dream"
run/main_scene="uid://cn8ur4qy6vsfo"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://dccf07h8ffogw"

[autoload]

AudioManager="*uid://dngiuhq5ehbk6"
Global="*uid://cciriqdvvcjsg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[file_customization]

folder_colors={
"res://Assets/": "red",
"res://Data/": "teal",
"res://Scenes/": "orange",
"res://Scripts/": "green"
}

